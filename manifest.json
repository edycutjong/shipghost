{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write",
    "chat.append_artifact",
    "chat.write_message",
    "llm.complete",
    "ui.svg"
  ],
  "required_executas": [
    {
      "tool_id": "tool-dev-shipghost",
      "min_version": "1.2.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "You are ShipGhost, a git PR helper. Instruct the user to open open_app_view('inline_inspector') to review suggested comments or open_app_view('commit_cleaner') to clean commits. Use agent sessions for iterative PR refinement. Upload descriptions to R2. Use embeddings for semantic commit grouping.",
  "user_message_prefix_template": "[ShipGhost] {user_message}",
  "tags": ["git", "pull-request", "developer-tools", "ai", "security", "embeddings", "rag"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "ShipGhost Dashboard",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 640, "h": 480 },
        "default_size": { "w": 960, "h": 640 },
        "max_size": { "w": 1920, "h": 1200 },
        "resizable": true,
        "movable": true,
        "single_instance": true,
        "summary_template": "ShipGhost: drafting PR"
      },
      {
        "name": "inline_inspector",
        "title": "Inline Comment Inspector",
        "entry": "index.html#/inspector",
        "min_size": { "w": 480, "h": 360 },
        "default_size": { "w": 640, "h": 480 },
        "resizable": true,
        "movable": true
      },
      {
        "name": "commit_cleaner",
        "title": "Interactive Commit Cleaner",
        "entry": "index.html#/cleaner",
        "min_size": { "w": 480, "h": 360 },
        "default_size": { "w": 640, "h": 480 },
        "resizable": true,
        "movable": true
      }
    ],
    "host_api": {
      "tools": ["required:*"],
      "llm": ["complete", "embed"],
      "image": ["generate", "edit"],
      "agent": { "session": { "auto": true } },
      "chat": ["write_message", "append_artifact"],
      "storage": ["get", "set", "delete", "list"],
      "window": ["set_title", "open_view", "close"],
      "upload": ["inline", "negotiate", "confirm"]
    },
    "csp_overrides": {
      "img-src": ["https:"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "seed_storage": {},
    "user_id": 1
  }
}
